<start> := <grammar>

<grammar> := (GRAMMAR <elem>+)

<elem> := (RULE <IDENTIFIER> <metaExp>)
        | (COMPUTE (NAME <ATOM>) <grammar>)

<metaExp> := (LIST <metaExp> <metaExp>)
           | <metaAtom>
         
<metaAtom> := (ATOM <ATOMIC> <metaAtom>)
            | <atomic>

<atomic> := <ATOMIC>
          | (RUN <ATOMIC>)
          | ()

